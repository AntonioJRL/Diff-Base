<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record model="res.groups" id="group_botones_avance">
            <field name="name">Grupo Botones Avance</field>
            <field name="category_id" ref="project_modificaciones.module_category_control_obra" />
            <field name="users" eval="[(4, ref('base.user_admin'))]" />
            <field name="comment">Este grupo permite la visibilidad y permiso de los botones para confirmar el avance o asignar el avance a un orden de venta.</field>
        </record>

        <record model="res.groups" id="group_boton_borrador_avance">
            <field name="name">Boton Borrador Avance</field>
            <field name="category_id" ref="project_modificaciones.module_category_control_obra" />
            <field name="users" eval="[(4, ref('base.user_admin'))]" />
            <field name="comment">Este grupo permite la visibilidad y permiso del boton regresar a borrador el avance.</field>
        </record>
        <!--
        <record id="group_vistas_control" model="res.groups">
            <field name="name">Usuario Control (Vistas)</field>
            <field name="category_id" ref="project_modificaciones.module_category_control_obra" />
            <field name="users" eval="[(4, ref('base.user_admin'))]" />
        </record>
        -->
        <record id="permiso_global_aprobar_tarea" model="res.groups">
            <field name="name">Aprobador Global</field>
            <field name="category_id" ref="project_modificaciones.module_category_control_obra" />
            <field name="comment">Este grupo permite al usuario poder aprobar una actividad aunque no sea el aprobador asignado.</field>
            <field name="users" eval="[(4, ref('base.user_admin'))]" />
        </record>

        <!--Permiso y Reglas Fusión de Servicios Pendientes-->
        <record id="group_pending_service_merge_approver" model="res.groups">
            <field name="name">Aprobador/Fusionador de Servicios Pendientes</field>
            <field name="category_id" ref="project_modificaciones.module_category_control_obra" />
            <field name="comment">Permite ejecutar fusiones directas y aprobar solicitudes de fusión de servicios pendientes.</field>
            <field name="users" eval="[(4, ref('base.user_admin'))]" />
        </record>
        <record id="group_pending_service_merge_requester" model="res.groups">
            <field name="name">Solicitante de Fusión de Servicios Pendientes</field>
            <field name="category_id" ref="project_modificaciones.module_category_control_obra" />
            <field name="comment">Permite crear y consultar sus propias solicitudes de fusión sin ejecutar fusiones directas.</field>
        </record>
        <record id="rule_pending_merge_request_own" model="ir.rule">
            <field name="name">Solicitudes de fusión propias</field>
            <field name="model_id" ref="model_pending_merge_request" />
            <field name="domain_force">[('requester_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]" />
        </record>
        <record id="rule_pending_merge_request_approver_all" model="ir.rule">
            <field name="name">Solicitudes de fusión aprobador todas</field>
            <field name="model_id" ref="model_pending_merge_request" />
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('project_modificaciones.group_pending_service_merge_approver'))]" />
        </record>

        <!--Permisos y Reglas de la Vista Unificada-->
        <record id="rule_project_control_board_company" model="ir.rule">
            <field name="name">Tablero de Proyectos por Empresa</field>
            <field name="model_id" ref="model_project_control_board" />
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]" />
        </record>
    </data>
</odoo>